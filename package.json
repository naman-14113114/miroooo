{
  "name": "web-design-structure",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:uk": "pnpm --filter @store/uk dev",
    "dev:us": "pnpm --filter @store/us dev",
    "dev:ca": "pnpm --filter @store/ca dev",
    "dev:au": "pnpm --filter @store/au dev",
    "build:uk": "pnpm --filter @store/uk build",
    "build:us": "pnpm --filter @store/us build",
    "build:ca": "pnpm --filter @store/ca build",
    "build:au": "pnpm --filter @store/au build",
    "lint:uk": "pnpm --filter @store/uk lint",
    "lint:us": "pnpm --filter @store/us lint",
    "lint:ca": "pnpm --filter @store/ca lint",
    "lint:au": "pnpm --filter @store/au lint"
  },
  "devDependencies": {
    "turbo": "^2.8.6",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
